│   ├── test_hash_chain.py           # Verificacion de hash chain
│   └── plugin.test.ts               # 35 tests TypeScript con node --test
│
├── templates/                       # 5 templates de artifacts
│   ├── evidence-pack.template.yaml
│   ├── dynamic-plan.template.yaml
│   ├── impact-prediction.template.yaml
│   ├── impl-scaffold.template.yaml
│   └── tool-registry.template.yaml
│
├── routing-rules.json               # 10 reglas declarativas (R-001..R-010)
├── install.sh                       # Instalador en 7 pasos
└── dist/                            # Output de compilacion TypeScript
    ├── index.js                     # Plugin compilado (entry point)
    ├── tests/
    │   └── plugin.test.js           # Tests TS compilados
    └── ...                          # Resto de modulos compilados
```

