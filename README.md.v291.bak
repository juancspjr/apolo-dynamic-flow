## 5. Integracion con OpenCode

### Configuracion en `opencode.json`

```json
{
  "$schema": "https://opencode.ai/config.json",
  "plugin": {
    "apolo-dynamic-flow": "./plugin/index.ts"
  },
  "mcp": {
    "opencode-fastedit": {
      "type": "local",
      "command": ["npx", "-y", "opencode-fastedit"],
      "enabled": true,
      "description": "Edicion rapida y precisa de archivos (preferida sobre apply_diff)"
    },
    "@playwright/mcp": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true,
      "description": "Captura visual + interacciones reales del browser"
    },
    "@koderspa/mcp-skills": {
      "type": "local",
      "command": ["npx", "-y", "@koderspa/mcp-skills"],
      "enabled": true,
      "description": "Skills externas auto-cargadas segun la tarea"
    }
  },
  "apolo-dynamic-flow": {
    "config": {
      "circuit_breaker_policy": "fail-closed",
      "max_loops_per_phase": {
        "reanclaje": 2,
        "verdad": 2,
        "plan-indice": 2,
        "implementation": 4,
        "critical-validation": 2
      },
      "evidence_collection": {
        "auto_recollect_on_stale": true,
        "stale_check_interval_seconds": 300
      },
      "tests": {
        "auto_run_on_micro_change": true,
        "auto_rollback_on_fail": true,
        "rollback_strategy": "git-restore"
      },
      "telemetry": {
        "enabled": true,
        "panel_port": 8080
      },
      "tools": {
        "absorb_on_session_start": true,
        "health_check_interval_seconds": 300
      }
    }
  }
}
```

### Verificar integracion

```bash
# Con opencode instalado (npm install -g opencode-ai):
opencode --version

# Verificar que el plugin carga:
python3 scripts/python/hooks_validator.py --repo-root .
# Debe dar: 7/7 PASS — HEALTHY

# Iniciar sesion OpenCode y el plugin se carga automatico:
opencode
```

