{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://apolo.local/schemas/json/routing-rules.json",
  "title": "Routing Rules",
  "description": "Reglas declarativas de routing de agentes. Cada regla define un `when` (condiciones) y un `then` (next_agent + reason).",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "rules"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+$"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "when", "then"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^R-\\d{3}$"
          },
          "priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "when": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "phase": {
                "type": "string",
                "enum": [
                  "reanclaje",
                  "planning-bootstrap",
                  "asr",
                  "verdad",
                  "shaping",
                  "plan-indice",
                  "mp-validation",
                  "implementation",
                  "critical-validation",
                  "cierre-flow",
                  "blocked"
                ]
              },
              "artifacts_present": {
                "type": "array",
                "items": { "type": "string" }
              },
              "artifacts_absent": {
                "type": "array",
                "items": { "type": "string" }
              },
              "blocker_active": { "type": "boolean" },
              "mp_ready": { "type": "boolean" },
              "deep_evidence_required": { "type": "boolean" }
            }
          },
          "then": {
            "type": "object",
            "additionalProperties": false,
            "required": ["next_agent", "reason"],
            "properties": {
              "next_agent": {
                "type": "string",
                "enum": [
                  "orchestrator",
                  "planner",
                  "surface-scanner",
                  "truth-auditor",
                  "microplanner",
                  "implementer",
                  "mutation-guardian",
                  "evidence-acquisition",
                  "blocked",
                  "closed"
                ]
              },
              "reason": {
                "type": "string",
                "minLength": 10
              },
              "circuit_breaker": {
                "type": "boolean",
                "default": false
              }
            }
          }
        }
      }
    }
  }
}
