{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://apolo.local/schemas/json/loop-engine-decision.json",
  "title": "Loop Engine Decision Node (D-NNN)",
  "description": "Nodo de decisión del árbol del loop dinámico. Cada nodo representa un punto de decisión con hasta 5 branches.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "flow_id", "phase", "state", "branches", "created_at"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^D-\\d{3}$"
    },
    "flow_id": {
      "type": "string",
      "pattern": "^APOLO-\\d{8}-[A-Z0-9-]+$"
    },
    "phase": {
      "type": "string",
      "enum": [
        "reanclaje",
        "planning-bootstrap",
        "asr",
        "verdad",
        "shaping",
        "plan-indice",
        "mp-validation",
        "implementation",
        "critical-validation",
        "cierre-flow"
      ]
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifacts_present", "mp_active", "blocker_active", "iteration"],
      "properties": {
        "artifacts_present": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mp_active": {
          "type": ["string", "null"]
        },
        "blocker_active": {
          "type": "boolean"
        },
        "iteration": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "last_test_result": {
          "type": "object",
          "additionalProperties": false,
          "required": ["passed", "exit_code"],
          "properties": {
            "passed": { "type": "boolean" },
            "exit_code": { "type": "integer" },
            "duration_ms": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "branches": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["condition", "action", "next_node", "reasoning"],
        "properties": {
          "condition": {
            "type": "string",
            "enum": [
              "test_passes",
              "test_fails_retriable",
              "test_fails_terminal",
              "blocker_persists",
              "iteration_exceeded",
              "evidence_stale",
              "evidence_contradicts",
              "gate_pass",
              "gate_refine",
              "gate_escalate",
              "gate_block"
            ]
          },
          "action": {
            "type": "string",
            "enum": [
              "advance_phase",
              "retry_mp",
              "raise_blocker",
              "ask_operator",
              "circuit_break",
              "collect_evidence",
              "refine_plan",
              "rollback",
              "no_op"
            ]
          },
          "next_node": {
            "type": "string",
            "pattern": "^(D-\\d{3}|AUTO)$"
          },
          "reasoning": {
            "type": "string",
            "minLength": 10
          },
          "terminal": {
            "type": "boolean",
            "default": false
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "parent_node": {
      "type": ["string", "null"],
      "pattern": "^D-\\d{3}$"
    },
    "resolved_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "outcome": {
      "type": "string",
      "enum": [
        "test_passes",
        "test_fails_retriable",
        "test_fails_terminal",
        "blocker_persists",
        "iteration_exceeded",
        "evidence_stale",
        "evidence_contradicts",
        "gate_pass",
        "gate_refine",
        "gate_escalate",
        "gate_block"
      ]
    }
  }
}
