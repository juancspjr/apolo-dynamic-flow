{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://apolo.local/schemas/json/agent-io.json",
  "title": "Agent I/O Contract",
  "description": "Contrato inputs/outputs para los 8 agents del sistema apolo-dynamic-flow.",
  "type": "object",
  "additionalProperties": false,
  "required": ["agent", "version", "inputs", "outputs"],
  "properties": {
    "agent": {
      "type": "string",
      "enum": [
        "orchestrator",
        "planner",
        "surface-scanner",
        "truth-auditor",
        "microplanner",
        "implementer",
        "mutation-guardian",
        "evidence-acquisition"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+$"
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifacts", "context"],
      "properties": {
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "required": { "type": "boolean", "default": true },
              "description": { "type": "string" }
            }
          }
        },
        "context": {
          "type": "object",
          "additionalProperties": true,
          "required": ["flow_id", "phase", "objective"],
          "properties": {
            "flow_id": {
              "type": "string",
              "pattern": "^APOLO-\\d{8}-[A-Z0-9-]+$"
            },
            "phase": {
              "type": "string",
              "enum": [
                "reanclaje",
                "planning-bootstrap",
                "asr",
                "verdad",
                "shaping",
                "plan-indice",
                "mp-validation",
                "implementation",
                "critical-validation",
                "cierre-flow"
              ]
            },
            "objective": {
              "type": "string",
              "minLength": 10
            },
            "mp_id": {
              "type": "string",
              "pattern": "^MP-[A-Z0-9_-]+$"
            }
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifacts_produced", "decision"],
      "properties": {
        "artifacts_produced": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "schema"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "schema": {
                "type": "string",
                "enum": [
                  "flow-state",
                  "dynamic-plan",
                  "evidence-pack",
                  "test-result",
                  "tool-registry",
                  "telemetry-event",
                  "block-log",
                  "loop-engine-decision",
                  "routing-rules",
                  "runtime-audit-log",
                  "agent-io"
                ]
              }
            }
          }
        },
        "decision": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "value", "reasoning"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["next_agent", "admission", "block", "route", "complete"]
            },
            "value": { "type": "string", "minLength": 1 },
            "reasoning": { "type": "string", "minLength": 20 },
            "evidence_refs": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "path"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "file-snapshot",
                  "git-diff",
                  "git-log",
                  "symbol-list",
                  "endpoint-probe",
                  "db-query",
                  "screenshot",
                  "dom-snapshot",
                  "curl-response",
                  "test-output",
                  "runtime-log",
                  "schema-validation",
                  "mcp-capability"
                ]
              },
              "path": { "type": "string", "minLength": 1 },
              "reproducible": { "type": "boolean", "default": true }
            }
          }
        }
      }
    }
  }
}
