{
  "name": "apolo-dynamic-flow",
  "version": "2.7.0",
  "description": "Plugin de orquestacion de agentes para OpenCode. Agnostico al lenguaje (HTML, CSS, JS, React, Rust, C++, PHP, TS, Java, Go). 3 capas: Infrastructure, Deterministic, Intelligence. Self-healing, test gen, semantic search, refactoring, LLM bridge, cross-language analysis, function summaries, code generation, doc generation, project templates, onboarding, GitHub Actions.",
  "main": "plugin/index.ts",
  "scripts": {
    "test": "npx tsc && node --test dist/tests/plugin.test.js",
    "test:python": "python3 tests/run_all_tests.py",
    "test:atomic": "python3 tests/test_atomic.py",
    "test:security": "python3 tests/test_security.py",
    "test:quality": "python3 tests/test_quality.py",
    "test:intelligence": "python3 tests/test_intelligence.py",
    "test:all": "npm run test:python && npm run test:atomic && npm run test:security && npm run test:quality && npm run test:intelligence && npm run test",
    "inspect": "bash scripts/bash/apolo-inspect.sh",
    "panel": "bash scripts/bash/apolo-inspect.sh serve-panel",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "install-deps": "python3 scripts/python/install_deps.py",
    "onboard": "python3 scripts/python/onboarding.py --repo-root . --non-interactive",
    "generate-actions": "python3 scripts/python/github_actions.py --repo-root ."
  },
  "keywords": ["opencode","plugin","apolo","dynamic-flow","loop-engine","routing","mcp","parallel-agents","evidence-pack","telemetry","atomic-writes","concurrency-safe","security","allowlist","secret-detection","hash-chain","sandboxing","multi-language","code-quality","test-coverage","lsp","bfs-impact-prediction","self-healing","test-generation","semantic-search","refactoring","llm-bridge","cross-language","function-summaries","code-generation","doc-generation","project-templates","onboarding","github-actions"],
  "author": "",
  "license": "MIT",
  "devDependencies": { "@types/node": "^22.0.0", "typescript": "^5.5.0" },
  "engines": { "node": ">=18.0.0" }
}
