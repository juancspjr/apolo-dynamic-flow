{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "./plugin/index.ts"
  ],
  "mcp": {
    "@playwright/mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "@koderspa/mcp-skills": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@koderspa/mcp-skills@latest"
      ],
      "enabled": true
    },
    "opencode-fastedit": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "opencode-fastedit@latest"
      ],
      "enabled": false,
      "description": "Deshabilitado temporalmente - revisar nombre correcto en npm"
    },
    "opencode-pty": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "opencode-pty@latest"
      ],
      "enabled": false,
      "description": "Deshabilitado temporalmente - revisar nombre correcto en npm"
    },
    "@obsidian-owl/opencode-specwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@obsidian-owl/opencode-specwright@latest"
      ],
      "enabled": false
    },
    "@zenobius/opencode-skillful": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@zenobius/opencode-skillful@latest"
      ],
      "enabled": false
    },
    "@cortexkit/aft-opencode": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@cortexkit/aft-opencode@latest"
      ],
      "enabled": false
    },
    "opencode-caveman": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "opencode-caveman@latest"
      ],
      "enabled": false
    },
    "@tarquinen/opencode-dcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@tarquinen/opencode-dcp@latest"
      ],
      "enabled": false
    }
  }
}